# IntermedCars Environment Variables
# NEVER commit this file to version control

# Database
DB_DRIVER=sqlite
DB_HOST=localhost
DB_NAME=intermedcars
DB_USER=root
DB_PASS=
DB_PATH=/absolute/path/to/database/intermedcars.sqlite

# JWT Secret (REQUIRED — no fallback)
JWT_SECRET=change-this-to-a-random-secret-in-production

# App
APP_URL=http://localhost:8080
APP_ENV=development
APP_DEBUG=true

# Payment IBAN (Escrow)
PAYMENT_IBAN=000600008398497030137
PAYMENT_BENEFICIARY=Ebivandro Terbio Manuel Agostinho

# ProxyPay / Multicaixa Express
PROXYPAY_API_KEY=
PROXYPAY_POS_ID=0
PROXYPAY_SANDBOX=true
PROXYPAY_WEBHOOK_SECRET=

# External APIs
KYC_API_KEY=
KYC_API_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@intermedcars.co.ao

# SMS (KambaSMS)
KAMBA_API_KEY=
KAMBA_SENDER=IntermedCars
